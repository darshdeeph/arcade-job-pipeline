# Arcade.dev API key — get from https://api.arcade.dev/dashboard
ARCADE_API_KEY=your_arcade_api_key_here

# Anthropic API key — get from https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Sheets spreadsheet ID — leave blank on first run; the agent will
# create the "Job Pipeline" sheet automatically and print the ID to save here.
SHEETS_SPREADSHEET_ID=

# Your Gmail address (used as the Arcade user identity for OAuth)
GMAIL_USER_ID=your_gmail@gmail.com

# How many days back to scan Gmail (default: 30)
DAYS_TO_SCAN=30

# Max concurrent API calls in-flight at once — Anthropic + Arcade (default: 4)
CONCURRENCY=4
